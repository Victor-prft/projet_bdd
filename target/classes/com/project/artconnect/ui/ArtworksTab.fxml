<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn"  text="Titre"    prefWidth="200" />
            <TableColumn fx:id="artistColumn" text="Artiste"  prefWidth="150" />
            <TableColumn fx:id="typeColumn"   text="Medium"   prefWidth="120" />
            <TableColumn fx:id="priceColumn"  text="Prix (€)" prefWidth="90"  />
            <TableColumn fx:id="statusColumn" text="Statut"   prefWidth="100" />
        </columns>
    </TableView>

    <Separator />

    <TitledPane text="Ajouter / Modifier une œuvre" animated="false" expanded="true">
        <GridPane hgap="12.0" vgap="8.0">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>

            <Label text="Titre :"         GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="titleField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                       prefWidth="200" promptText="Titre de l'œuvre" />

            <Label text="Artiste :"       GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <ComboBox fx:id="artistCombo" GridPane.columnIndex="3" GridPane.rowIndex="0"
                      prefWidth="200" />

            <Label text="Medium :"         GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="mediumField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       prefWidth="200" promptText="ex: Huile sur toile" />

            <Label text="Année :"        GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="yearField" GridPane.columnIndex="3" GridPane.rowIndex="1"
                       prefWidth="200" promptText="ex: 2022" />

            <Label text="Prix (€) :"      GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="priceField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                       prefWidth="200" promptText="ex: 1500.00" />

            <Label text="Statut :"         GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <ComboBox fx:id="statusCombo"  GridPane.columnIndex="3" GridPane.rowIndex="2"
                      prefWidth="200" />

            <HBox spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="4">
                <Button text="Ajouter"       onAction="#handleAdd"    style="-fx-base: #4caf50;" />
                <Button text="Mettre à jour" onAction="#handleUpdate" style="-fx-base: #2196f3;" />
                <Button text="Supprimer"     onAction="#handleDelete" style="-fx-base: #f44336;" />
                <Button text="Effacer"       onAction="#handleClear" />
            </HBox>

            <Label fx:id="statusLabel" GridPane.columnIndex="0" GridPane.rowIndex="4"
                   GridPane.columnSpan="4" style="-fx-text-fill: #388e3c;" />
        </GridPane>
    </TitledPane>
</VBox>