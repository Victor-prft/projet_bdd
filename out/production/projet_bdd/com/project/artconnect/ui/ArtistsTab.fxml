<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtistController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <!-- Barre de recherche -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher un artiste..." HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="disciplineFilter" promptText="Filtrer par discipline" />
        <Button text="Rechercher" onAction="#handleSearch" />
        <Button text="Réinitialiser" onAction="#handleReset" />
    </HBox>

    <!-- Tableau des artistes -->
    <TableView fx:id="artistTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn"  text="Nom"              prefWidth="180" />
            <TableColumn fx:id="cityColumn"  text="Ville"            prefWidth="130" />
            <TableColumn fx:id="emailColumn" text="Email"            prefWidth="200" />
            <TableColumn fx:id="yearColumn"  text="Année naissance"  prefWidth="120" />
        </columns>
    </TableView>

    <!-- Séparateur -->
    <Separator />

    <!-- Formulaire CRUD -->
    <TitledPane text="Ajouter / Modifier un artiste" animated="false" expanded="true">
        <GridPane hgap="12.0" vgap="8.0">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>

            <Label text="Nom :"          GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200" promptText="Nom complet" />

            <Label text="Email :"         GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="emailField" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="200" promptText="contact@email.com" />

            <Label text="Ville :"        GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="cityField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="200" promptText="Nom de la ville" />

            <Label text="Année de naissance :"   GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="birthYearField"    GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="200" promptText="ex: 1985" />

            <HBox spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="4">
                <Button text="Ajouter"          onAction="#handleAdd"    style="-fx-base: #4caf50;" />
                <Button text="Mettre à jour"    onAction="#handleUpdate" style="-fx-base: #2196f3;" />
                <Button text="Supprimer"        onAction="#handleDelete" style="-fx-base: #f44336;" />
                <Button text="Effacer"          onAction="#handleClear" />
            </HBox>

            <Label fx:id="statusLabel" GridPane.columnIndex="0" GridPane.rowIndex="3"
                   GridPane.columnSpan="4" style="-fx-text-fill: #388e3c;" />
        </GridPane>
    </TitledPane>
</VBox>